<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.arlocationqr">

    <!-- ✅ 권한 및 기능 선언은 application 위쪽에! -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- ✅ ARCore 및 OpenGL ES 3.0 필수 설정 -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="true" />
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />

    <!-- ✅ 여기부터가 app 실제 구조 -->
    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ARLocationQR">

        <!-- ✅ 메인 화면 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ✅ QR 카메라 -->
        <activity
            android:name=".qr.QrActivity"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:exported="true" />

        <!-- ✅ 목적지 검색 -->
        <activity
            android:name=".DestinationActivity"
            android:exported="true" />

        <!-- ✅ AR 내비게이션 -->
        <activity
            android:name=".ar.ArNavigationActivity"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:exported="true" />
    </application>
</manifest>


